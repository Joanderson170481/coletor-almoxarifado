<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="theme-color" content="#0f2027">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<title>Coletor · Almoxarifado</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600&display=swap" rel="stylesheet">
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-firestore-compat.js"></script>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
:root{
  --bg:#0f2027;--bg2:#162530;--bg3:#1d3040;
  --accent:#00d4aa;--warn:#f5a623;--danger:#e05252;
  --text:#e8f4f0;--text2:#8ab8ae;--text3:#4a7a70;
  --border:rgba(0,212,170,0.15);--border2:rgba(0,212,170,0.30);
  --mono:'IBM Plex Mono',monospace;--sans:'IBM Plex Sans',sans-serif;
  --radius:12px;
  --safe-top:env(safe-area-inset-top,0px);
  --safe-bot:env(safe-area-inset-bottom,0px);
}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:var(--sans);font-size:16px;line-height:1.5;overscroll-behavior:none}
.screen{display:none;flex-direction:column;min-height:100vh;min-height:100dvh;padding-top:var(--safe-top);padding-bottom:var(--safe-bot);animation:fadeIn .2s ease}
.screen.active{display:flex}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
.topbar{display:flex;align-items:center;gap:10px;padding:14px 16px 10px;border-bottom:1px solid var(--border);background:var(--bg);position:sticky;top:0;z-index:10}
.topbar-back{width:36px;height:36px;border-radius:8px;background:var(--bg3);border:1px solid var(--border);color:var(--accent);font-size:18px;display:flex;align-items:center;justify-content:center;cursor:pointer}
.topbar-title{font-family:var(--mono);font-size:13px;font-weight:600;color:var(--accent);letter-spacing:.5px;flex:1}
.topbar-sub{font-size:10px;color:var(--text3);font-family:var(--mono)}
.topbar-badge{font-family:var(--mono);font-size:10px;background:var(--bg3);border:1px solid var(--border);color:var(--text2);padding:3px 8px;border-radius:20px}
.scroll-body{flex:1;overflow-y:auto;padding:16px;display:flex;flex-direction:column;gap:12px}
.card{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px}
.card-label{font-size:10px;font-family:var(--mono);color:var(--text3);text-transform:uppercase;letter-spacing:.8px;margin-bottom:4px}
.card-value{font-size:15px;font-weight:500;color:var(--text)}
.card-value.mono{font-family:var(--mono)}
.card-value.big{font-size:28px;font-family:var(--mono);color:var(--accent);font-weight:600}
.field-group{display:flex;flex-direction:column;gap:6px}
.field-label{font-size:11px;font-family:var(--mono);color:var(--text3);text-transform:uppercase;letter-spacing:.6px}
input[type=text],input[type=password],input[type=number]{width:100%;background:var(--bg3);border:1px solid var(--border2);border-radius:8px;color:var(--text);font-family:var(--mono);font-size:16px;padding:12px 14px;outline:none;transition:border-color .15s;-webkit-appearance:none}
input:focus{border-color:var(--accent)}
input::placeholder{color:var(--text3)}
input[type=number]{font-size:22px;text-align:center;padding:14px;letter-spacing:2px}
.btn{width:100%;padding:14px;border-radius:var(--radius);border:none;font-family:var(--mono);font-size:14px;font-weight:600;letter-spacing:.5px;cursor:pointer;transition:opacity .15s,transform .1s;display:flex;align-items:center;justify-content:center;gap:8px}
.btn:active{transform:scale(.97)}
.btn-primary{background:var(--accent);color:#0f2027}
.btn-primary:disabled{opacity:.4;cursor:not-allowed}
.btn-secondary{background:var(--bg3);color:var(--accent);border:1px solid var(--border2)}
.qty-control{display:grid;grid-template-columns:56px 1fr 56px;gap:8px;align-items:center}
.qty-btn{height:56px;border-radius:10px;background:var(--bg3);border:1px solid var(--border2);color:var(--accent);font-size:26px;cursor:pointer;display:flex;align-items:center;justify-content:center;font-family:var(--mono)}
.qty-btn:active{background:var(--bg)}
.badge{display:inline-block;padding:3px 10px;border-radius:20px;font-size:10px;font-family:var(--mono);font-weight:600;text-transform:uppercase;letter-spacing:.5px}
.badge-ok{background:rgba(0,212,170,.15);color:var(--accent);border:1px solid rgba(0,212,170,.3)}
.badge-warn{background:rgba(245,166,35,.15);color:var(--warn);border:1px solid rgba(245,166,35,.3)}
.badge-danger{background:rgba(224,82,82,.15);color:var(--danger);border:1px solid rgba(224,82,82,.3)}
.badge-neutral{background:var(--bg3);color:var(--text2);border:1px solid var(--border)}
.list-item{background:var(--bg2);border:1px solid var(--border);border-radius:var(--radius);padding:12px 14px;display:flex;align-items:center;gap:12px;cursor:pointer;transition:border-color .15s}
.list-item:active{border-color:var(--accent);background:var(--bg3)}
.list-item-icon{width:40px;height:40px;border-radius:10px;background:var(--bg3);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
.list-item-info{flex:1;min-width:0}
.list-item-title{font-size:14px;font-weight:500;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.list-item-sub{font-size:11px;color:var(--text2);font-family:var(--mono);margin-top:2px}
.product-row{background:var(--bg3);border-radius:8px;padding:10px 12px;margin-bottom:8px;border-left:3px solid var(--border2);display:flex;align-items:center;gap:10px}
.product-row.done{border-left-color:var(--accent);opacity:.6}
.product-row.divergente{border-left-color:var(--danger)}
.notif{position:fixed;top:calc(var(--safe-top) + 60px);left:16px;right:16px;padding:12px 16px;border-radius:var(--radius);font-family:var(--mono);font-size:13px;font-weight:500;z-index:100;transform:translateY(-10px);opacity:0;transition:all .25s ease;pointer-events:none}
.notif.show{transform:translateY(0);opacity:1}
.notif.success{background:rgba(0,212,170,.2);color:var(--accent);border:1px solid rgba(0,212,170,.4)}
.notif.error{background:rgba(224,82,82,.2);color:var(--danger);border:1px solid rgba(224,82,82,.4)}
.notif.info{background:rgba(245,166,35,.15);color:var(--warn);border:1px solid rgba(245,166,35,.3)}
.divider{border:none;border-top:1px solid var(--border);margin:4px 0}
.loading-overlay{position:fixed;inset:0;background:rgba(15,32,39,.85);display:flex;align-items:center;justify-content:center;z-index:200;display:none}
.spinner{width:36px;height:36px;border-radius:50%;border:3px solid var(--border2);border-top-color:var(--accent);animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
#screen-login{justify-content:center;background:linear-gradient(160deg,#0f2027 0%,#162530 60%,#0f2027 100%)}
.login-wrap{padding:24px 24px 32px;display:flex;flex-direction:column;gap:20px}
.login-logo{text-align:center;padding:8px 0 24px}
.login-logo-mark{display:inline-flex;align-items:center;justify-content:center;width:64px;height:64px;border-radius:16px;background:rgba(0,212,170,.1);border:2px solid rgba(0,212,170,.3);font-size:28px;margin-bottom:12px}
.login-title{font-family:var(--mono);font-size:20px;font-weight:600;color:var(--accent)}
.login-sub{font-size:12px;color:var(--text3);margin-top:4px;letter-spacing:.3px}
.tabs{display:flex;gap:4px;padding:12px 16px 0}
.tab{flex:1;padding:8px 6px;border-radius:8px 8px 0 0;background:var(--bg3);border:1px solid var(--border);border-bottom:none;color:var(--text3);font-family:var(--mono);font-size:11px;font-weight:600;text-align:center;cursor:pointer;letter-spacing:.3px;transition:all .15s}
.tab.active{background:var(--bg2);color:var(--accent);border-color:var(--border2)}
.row2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.prog-bar{height:6px;background:var(--bg3);border-radius:3px;overflow:hidden}
.prog-fill{height:100%;background:var(--accent);border-radius:3px;transition:width .3s ease}
.empty{text-align:center;padding:32px 16px;color:var(--text3);font-family:var(--mono);font-size:12px}
.empty-icon{font-size:32px;margin-bottom:10px}
#modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:150;align-items:flex-end;justify-content:center}
.modal-box{background:var(--bg2);border:1px solid var(--border2);border-radius:20px 20px 0 0;padding:20px 20px calc(20px + var(--safe-bot));width:100%;max-width:480px;animation:slideUp .25s ease}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
</style>
</head>
<body>
<div class="notif" id="notif"></div>
<div class="loading-overlay" id="loading"><div class="spinner"></div></div>

<!-- LOGIN -->
<div class="screen active" id="screen-login">
  <div class="login-wrap">
    <div class="login-logo">
      <div class="login-logo-mark">📦</div>
      <div class="login-title">COLETOR</div>
      <div class="login-sub">Sistema de Inventário · Almoxarifado</div>
    </div>
    <div class="field-group">
      <div class="field-label">Login</div>
      <input type="text" id="inp-login" placeholder="seu.login" autocomplete="username" autocapitalize="none">
    </div>
    <div class="field-group">
      <div class="field-label">Senha</div>
      <input type="password" id="inp-senha" placeholder="••••••••" autocomplete="current-password">
    </div>
    <button class="btn btn-primary" onclick="doLogin()">ENTRAR</button>
    <div style="text-align:center;font-size:11px;color:var(--text3);font-family:var(--mono)">v1.0-TESTE · Modo Inventário</div>
  </div>
</div>

<!-- HOME ALMOXARIFE -->
<div class="screen" id="screen-home">
  <div class="topbar">
    <div style="flex:1">
      <div class="topbar-title" id="home-greeting">Olá</div>
      <div class="topbar-sub" id="home-perfil">almoxarife</div>
    </div>
    <div class="topbar-badge" id="home-hora">--:--</div>
    <div style="cursor:pointer;color:var(--text3);padding:4px 8px;font-size:18px" onclick="doLogout()">⏻</div>
  </div>
  <div class="scroll-body">
    <div class="card">
      <div class="card-label">Sessão ativa</div>
      <div id="home-sessao-nome" class="card-value" style="margin-bottom:4px">Nenhuma sessão aberta</div>
      <div id="home-sessao-status"></div>
    </div>
    <div id="home-rodada-info" style="display:none;flex-direction:column;gap:10px">
      <div class="row2">
        <div class="card" style="text-align:center">
          <div class="card-label">Rodada</div>
          <div class="card-value big" id="home-rodada-num">1</div>
        </div>
        <div class="card" style="text-align:center">
          <div class="card-label">Contadas</div>
          <div class="card-value big" id="home-contadas">0</div>
        </div>
      </div>
      <button class="btn btn-primary" onclick="goContagem()" id="btn-iniciar-contagem">
        <span>📋</span> INICIAR CONTAGEM
      </button>
    </div>
    <div class="card">
      <div class="card-label">Seu histórico hoje</div>
      <div id="home-historico">
        <div class="empty" style="padding:16px 0"><div style="font-size:20px;margin-bottom:6px">📭</div>Nenhuma contagem realizada</div>
      </div>
    </div>
  </div>
</div>

<!-- CONTAGEM -->
<div class="screen" id="screen-contagem">
  <div class="topbar">
    <div class="topbar-back" onclick="goHome()">←</div>
    <div style="flex:1">
      <div class="topbar-title">CONTAGEM</div>
      <div class="topbar-sub" id="cont-rodada-label">1ª Rodada</div>
    </div>
    <div class="topbar-badge" id="cont-progress-badge">0/0</div>
  </div>
  <div class="scroll-body">
    <div class="card">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:8px">
        <div class="card-label" style="margin:0">Progresso</div>
        <div style="font-size:11px;font-family:var(--mono);color:var(--text2)" id="cont-prog-txt">0 de 0 produtos</div>
      </div>
      <div class="prog-bar"><div class="prog-fill" id="cont-prog-fill" style="width:0%"></div></div>
    </div>
    <div class="card">
      <div class="field-group" style="margin-bottom:12px">
        <div class="field-label">Código SAP do Produto</div>
        <input type="text" id="cont-codigo" placeholder="SAP-10001" autocapitalize="characters"
               oninput="this.value=this.value.toUpperCase()" onkeydown="if(event.key==='Enter')buscarProduto()">
      </div>
      <button class="btn btn-secondary" onclick="buscarProduto()">🔍 BUSCAR PRODUTO</button>
    </div>
    <div id="cont-produto-card" style="display:none">
      <div class="card" style="border-color:var(--border2)">
        <div style="margin-bottom:10px">
          <div class="card-label">Produto encontrado</div>
          <div class="card-value" id="cont-prod-nome" style="margin-bottom:2px"></div>
          <div style="display:flex;gap:8px;align-items:center;margin-top:4px">
            <span style="font-size:11px;font-family:var(--mono);color:var(--text3)" id="cont-prod-cod"></span>
            <span id="cont-prod-badge"></span>
          </div>
        </div>
        <div class="row2" style="margin-bottom:14px">
          <div><div class="card-label">Localização</div><div class="card-value mono" id="cont-prod-loc">—</div></div>
          <div><div class="card-label">Unidade</div><div class="card-value mono" id="cont-prod-un">—</div></div>
        </div>
        <div class="field-group">
          <div class="field-label">Quantidade contada</div>
          <div class="qty-control">
            <div class="qty-btn" onclick="alterarQty(-1)">−</div>
            <input type="number" id="cont-qty" value="0" min="0" step="1">
            <div class="qty-btn" onclick="alterarQty(1)">+</div>
          </div>
        </div>
        <div class="field-group" style="margin-top:12px">
          <div class="field-label">Observação (opcional)</div>
          <input type="text" id="cont-obs" placeholder="ex: embalagem aberta...">
        </div>
        <button class="btn btn-primary" onclick="confirmarContagem()" style="margin-top:14px">✓ CONFIRMAR CONTAGEM</button>
      </div>
    </div>
    <div>
      <div style="font-size:11px;font-family:var(--mono);color:var(--text3);text-transform:uppercase;letter-spacing:.6px;margin-bottom:8px">Contados nesta sessão</div>
      <div id="cont-lista-contados"><div class="empty"><div class="empty-icon">📋</div>Nenhum item contado ainda</div></div>
    </div>
  </div>
</div>

<!-- SUPERVISOR -->
<div class="screen" id="screen-supervisor">
  <div class="topbar">
    <div style="flex:1">
      <div class="topbar-title">SUPERVISOR</div>
      <div class="topbar-sub" id="sup-nome">—</div>
    </div>
    <div style="cursor:pointer;color:var(--text3);padding:4px 8px;font-size:18px" onclick="doLogout()">⏻</div>
  </div>
  <div class="tabs">
    <div class="tab active" id="tab-sessoes" onclick="supTab('sessoes')">SESSÕES</div>
    <div class="tab" id="tab-resumo" onclick="supTab('resumo')">RESUMO</div>
    <div class="tab" id="tab-diverg" onclick="supTab('diverg')">DIVERG.</div>
  </div>
  <div id="sup-tab-sessoes" class="scroll-body">
    <button class="btn btn-primary" onclick="abrirModalNovaSessao()">+ NOVA SESSÃO DE INVENTÁRIO</button>
    <div id="sup-lista-sessoes"><div class="empty"><div class="empty-icon">🗂️</div>Nenhuma sessão criada</div></div>
  </div>
  <div id="sup-tab-resumo" class="scroll-body" style="display:none">
    <div class="row2">
      <div class="card" style="text-align:center"><div class="card-label">Total</div><div class="card-value big" id="res-total">0</div></div>
      <div class="card" style="text-align:center"><div class="card-label">Contados</div><div class="card-value big" id="res-contados">0</div></div>
    </div>
    <div class="row2">
      <div class="card" style="text-align:center"><div class="card-label">OK</div><div class="card-value big" style="color:var(--accent)" id="res-ok">0</div></div>
      <div class="card" style="text-align:center"><div class="card-label">Divergentes</div><div class="card-value big" style="color:var(--danger)" id="res-div">0</div></div>
    </div>
    <div id="sup-resumo-lista"><div class="empty"><div class="empty-icon">📊</div>Selecione uma sessão</div></div>
  </div>
  <div id="sup-tab-diverg" class="scroll-body" style="display:none">
    <div id="sup-diverg-lista"><div class="empty"><div class="empty-icon">✅</div>Nenhuma divergência</div></div>
    <button class="btn btn-secondary" onclick="exportarCSV()" id="btn-export" style="display:none">⬇ EXPORTAR CSV</button>
  </div>
</div>

<!-- MODAL NOVA SESSÃO -->
<div id="modal-overlay" onclick="if(event.target===this)fecharModal()">
  <div class="modal-box">
    <div style="font-family:var(--mono);font-size:14px;font-weight:600;color:var(--accent);margin-bottom:16px">NOVA SESSÃO</div>
    <div class="field-group" style="margin-bottom:12px">
      <div class="field-label">Descrição</div>
      <input type="text" id="modal-sessao-desc" placeholder="ex: Inventário Geral — Maio/2026">
    </div>
    <button class="btn btn-primary" onclick="criarSessao()">CRIAR SESSÃO</button>
  </div>
</div>

