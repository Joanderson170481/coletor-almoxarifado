  {id:'p15',codigo_sap:'SAP-10015',descricao:'Tinta Epóxi Cinza 18L',     unidade:'GL',localizacao:'H-01-01'},
];

// ═══════════════════ ESTADO ═══════════════════
let state = {user:null, sessaoAtiva:null, produtoAtual:null, contadosSessao:[], supSessaoId:null};

// ═══════════════════ UTILS ═══════════════════
function showScreen(id){document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));document.getElementById('screen-'+id).classList.add('active');window.scrollTo(0,0)}
function loading(v){document.getElementById('loading').style.display=v?'flex':'none'}
let _nt;
function notify(msg,type='success'){const el=document.getElementById('notif');el.textContent=msg;el.className='notif '+type+' show';clearTimeout(_nt);_nt=setTimeout(()=>el.classList.remove('show'),3000)}
function hora(){return new Date().toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'})}
function uid(){return Date.now().toString(36)+Math.random().toString(36).slice(2)}

// ═══════════════════ LOGIN ═══════════════════
async function doLogin(){
  const login=document.getElementById('inp-login').value.trim().toLowerCase();
  const senha=document.getElementById('inp-senha').value;
  if(!login||!senha){notify('Preencha login e senha','error');return}
  const user=USUARIOS.find(u=>u.login===login&&u.senha===senha);
  if(!user){notify('Login ou senha incorretos','error');return}
  state.user=user;
  sessionStorage.setItem('coletor_user',JSON.stringify(user));
  if(user.perfil==='supervisor') await loadSupervisor();
  else await loadHome();
}

function doLogout(){
  state={user:null,sessaoAtiva:null,produtoAtual:null,contadosSessao:[],supSessaoId:null};
  sessionStorage.removeItem('coletor_user');
  document.getElementById('inp-login').value='';
  document.getElementById('inp-senha').value='';
  showScreen('login');
}

// ═══════════════════ HOME ALMOXARIFE ═══════════════════
async function loadHome(){
  const u=state.user;
  document.getElementById('home-greeting').textContent='Olá, '+u.nome.split(' ')[0];
  document.getElementById('home-perfil').textContent=u.perfil+' · '+hora();
  document.getElementById('home-hora').textContent=hora();
  loading(true);
  try{
    const snap=await db.collection('sessoes').where('status','in',['aberta','em_contagem']).limit(1).get();
    const sessao=snap.empty?null:{id:snap.docs[0].id,...snap.docs[0].data()};
    state.sessaoAtiva=sessao;
    const nomeEl=document.getElementById('home-sessao-nome');
    const statusEl=document.getElementById('home-sessao-status');
    const rodadaInfo=document.getElementById('home-rodada-info');
    if(!sessao){
      nomeEl.textContent='Nenhuma sessão ativa';
      statusEl.innerHTML='<span class="badge badge-neutral">aguardando supervisor</span>';
      rodadaInfo.style.display='none';
    } else {
      nomeEl.textContent=sessao.descricao;
      statusEl.innerHTML='<span class="badge badge-ok">em andamento · rodada '+sessao.rodada_atual+'</span>';
      rodadaInfo.style.display='flex';
      document.getElementById('home-rodada-num').textContent=sessao.rodada_atual;
      document.getElementById('cont-rodada-label').textContent=sessao.rodada_atual===1?'1ª Rodada':'2ª Rodada';
      // Buscar contagens do usuário
      const cSnap=await db.collection('contagens')
        .where('sessao_id','==',sessao.id)
        .where('usuario_id','==',u.id)
        .where('rodada','==',sessao.rodada_atual).get();
      state.contadosSessao=cSnap.docs.map(d=>({id:d.id,...d.data()}));
      document.getElementById('home-contadas').textContent=state.contadosSessao.length;
      renderHistorico(state.contadosSessao);
      // Bloquear se fez rodada 1 e agora é rodada 2
      if(sessao.rodada_atual===2){
        const r1Snap=await db.collection('contagens')
          .where('sessao_id','==',sessao.id)
          .where('usuario_id','==',u.id)
          .where('rodada','==',1).get();
        if(!r1Snap.empty){
          document.getElementById('btn-iniciar-contagem').disabled=true;
          document.getElementById('btn-iniciar-contagem').textContent='⛔ Já fez a 1ª contagem';
        } else {
          document.getElementById('btn-iniciar-contagem').disabled=false;
          document.getElementById('btn-iniciar-contagem').innerHTML='<span>📋</span> INICIAR CONTAGEM';
        }
      } else {
        document.getElementById('btn-iniciar-contagem').disabled=false;
        document.getElementById('btn-iniciar-contagem').innerHTML='<span>📋</span> INICIAR CONTAGEM';
      }
    }
  } catch(e){notify('Erro ao carregar: '+e.message,'error')}
  loading(false);
  showScreen('home');
}

function renderHistorico(lista){
  const el=document.getElementById('home-historico');
  if(!lista.length){el.innerHTML='<div class="empty" style="padding:12px 0"><div style="font-size:18px;margin-bottom:4px">📭</div>Nenhuma contagem realizada</div>';return}
  el.innerHTML=lista.slice(-6).reverse().map(c=>`
    <div class="product-row done">
      <div style="flex:1;min-width:0">
        <div style="font-size:12px;font-family:var(--mono);color:var(--text)">${c.codigo_sap}</div>
        <div style="font-size:10px;color:var(--text3)">${c.descricao||''}</div>
      </div>
      <div style="font-family:var(--mono);font-size:15px;font-weight:600;color:var(--accent)">${c.quantidade}</div>
    </div>`).join('');
}

// ═══════════════════ CONTAGEM ═══════════════════
function goContagem(){
  document.getElementById('cont-codigo').value='';
  document.getElementById('cont-qty').value='0';
  document.getElementById('cont-obs').value='';
  document.getElementById('cont-produto-card').style.display='none';
  renderContados();
  updateProgress();
  showScreen('contagem');
  setTimeout(()=>document.getElementById('cont-codigo').focus(),300);
}

function goHome(){loadHome()}

function buscarProduto(){
  const codigo=document.getElementById('cont-codigo').value.trim().toUpperCase();
  if(!codigo){notify('Digite o código SAP','error');return}
  const prod=PRODUTOS.find(p=>p.codigo_sap===codigo);
  if(!prod){notify('Código não encontrado: '+codigo,'error');return}
  const jaCont=state.contadosSessao.find(c=>c.produto_id===prod.id);
  state.produtoAtual=prod;
  document.getElementById('cont-prod-nome').textContent=prod.descricao;
  document.getElementById('cont-prod-cod').textContent=prod.codigo_sap;
  document.getElementById('cont-prod-loc').textContent=prod.localizacao||'—';
  document.getElementById('cont-prod-un').textContent=prod.unidade;
  document.getElementById('cont-prod-badge').innerHTML=jaCont
    ?`<span class="badge badge-warn">já contado: ${jaCont.quantidade} ${prod.unidade}</span>`
    :`<span class="badge badge-ok">pronto para contar</span>`;
  document.getElementById('cont-qty').value=jaCont?jaCont.quantidade:'0';
  document.getElementById('cont-produto-card').style.display='block';
  document.getElementById('cont-qty').focus();
  document.getElementById('cont-qty').select();
}

function alterarQty(delta){
  const inp=document.getElementById('cont-qty');
  inp.value=Math.max(0,(parseFloat(inp.value)||0)+delta);
}

async function confirmarContagem(){
  const prod=state.produtoAtual;
  const sessao=state.sessaoAtiva;
  if(!prod||!sessao){notify('Sessão ou produto inválido','error');return}
  const qty=parseFloat(document.getElementById('cont-qty').value)||0;
  const obs=document.getElementById('cont-obs').value.trim();
  loading(true);
  try{
    // Remover contagem anterior se existir
    const existing=state.contadosSessao.find(c=>c.produto_id===prod.id);
    if(existing&&existing.id){await db.collection('contagens').doc(existing.id).delete()}
    const row={
      sessao_id:sessao.id, usuario_id:state.user.id, usuario_nome:state.user.nome,
      produto_id:prod.id, codigo_sap:prod.codigo_sap, descricao:prod.descricao,
      quantidade:qty, rodada:sessao.rodada_atual, observacao:obs||null,
      criado_em:firebase.firestore.FieldValue.serverTimestamp()
    };
    const ref=await db.collection('contagens').add(row);
    const idx=state.contadosSessao.findIndex(c=>c.produto_id===prod.id);
    if(idx>=0)state.contadosSessao.splice(idx,1);
    state.contadosSessao.push({id:ref.id,...row});
    notify('✓ '+prod.codigo_sap+' — '+qty+' '+prod.unidade,'success');
    document.getElementById('cont-codigo').value='';
    document.getElementById('cont-produto-card').style.display='none';
    document.getElementById('cont-qty').value='0';
    document.getElementById('cont-obs').value='';
    renderContados();
    updateProgress();
    document.getElementById('home-contadas').textContent=state.contadosSessao.length;
    setTimeout(()=>document.getElementById('cont-codigo').focus(),200);
  }catch(e){notify('Erro ao salvar: '+e.message,'error')}
  loading(false);
}

function renderContados(){
  const el=document.getElementById('cont-lista-contados');
  const lista=state.contadosSessao;
  if(!lista.length){el.innerHTML='<div class="empty"><div class="empty-icon">📋</div>Nenhum item contado ainda</div>';return}
  el.innerHTML=lista.slice().reverse().map(c=>`
    <div class="product-row done">
      <div style="flex:1;min-width:0">
        <div style="font-size:12px;font-family:var(--mono);color:var(--text)">${c.codigo_sap}</div>
        <div style="font-size:10px;color:var(--text3);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${c.descricao||''}</div>
      </div>
      <div style="font-family:var(--mono);font-size:15px;font-weight:600;color:var(--accent)">${c.quantidade}</div>
    </div>`).join('');
}

function updateProgress(){
  const total=PRODUTOS.length;
  const done=state.contadosSessao.length;
  const pct=total?Math.round(done/total*100):0;
  document.getElementById('cont-progress-badge').textContent=done+'/'+total;
  document.getElementById('cont-prog-txt').textContent=done+' de '+total+' produtos';
  document.getElementById('cont-prog-fill').style.width=pct+'%';
}

// ═══════════════════ SUPERVISOR ═══════════════════
async function loadSupervisor(){
  document.getElementById('sup-nome').textContent=state.user.nome;
  showScreen('supervisor');
  await supTab('sessoes');
}

async function supTab(tab){
  ['sessoes','resumo','diverg'].forEach(t=>{
    document.getElementById('tab-'+t).classList.toggle('active',t===tab);
    document.getElementById('sup-tab-'+t).style.display=t===tab?'flex':'none';
  });
  if(tab==='sessoes')await renderSessoes();
  if(tab==='resumo')await renderResumo();
  if(tab==='diverg')await renderDivergencias();
}

async function renderSessoes(){
  loading(true);
  try{
    const snap=await db.collection('sessoes').orderBy('criado_em','desc').get();
    const el=document.getElementById('sup-lista-sessoes');
    if(snap.empty){el.innerHTML='<div class="empty"><div class="empty-icon">🗂️</div>Nenhuma sessão criada</div>';loading(false);return}
    const statusMap={aberta:{badge:'badge-ok',label:'aberta'},em_contagem:{badge:'badge-warn',label:'em contagem'},aguardando_revisao:{badge:'badge-danger',label:'aguardando revisão'},fechada:{badge:'badge-neutral',label:'fechada'}};
    el.innerHTML=snap.docs.map(d=>{
      const s={id:d.id,...d.data()};
      const sm=statusMap[s.status]||{badge:'badge-neutral',label:s.status};
      return `<div class="list-item" onclick="selecionarSessao('${s.id}')">
        <div class="list-item-icon">📋</div>
        <div class="list-item-info">
          <div class="list-item-title">${s.descricao}</div>
          <div class="list-item-sub"><span class="badge ${sm.badge}" style="font-size:9px">${sm.label}</span> &nbsp; rodada ${s.rodada_atual}</div>
        </div>
        ${s.status!=='fechada'?`<button class="btn btn-secondary" style="padding:5px 10px;font-size:10px;width:auto" onclick="event.stopPropagation();avancarRodada('${s.id}','${s.rodada_atual}','${s.status}')">AVANÇAR</button>`:''}
      </div>`;
    }).join('');
  }catch(e){notify('Erro: '+e.message,'error')}
  loading(false);
}

async function selecionarSessao(id){
  state.supSessaoId=id;
  await supTab('resumo');
}

async function renderResumo(){
  if(!state.supSessaoId){document.getElementById('sup-resumo-lista').innerHTML='<div class="empty"><div class="empty-icon">📊</div>Clique em uma sessão</div>';return}
  loading(true);
  try{
    const cSnap=await db.collection('contagens').where('sessao_id','==',state.supSessaoId).get();
    const c1={},c2={};
    cSnap.docs.forEach(d=>{const c=d.data();if(c.rodada===1)c1[c.codigo_sap]=c;else if(c.rodada===2)c2[c.codigo_sap]=c;});
    let total=PRODUTOS.length,contados=0,ok=0,div=0;
    const rows=PRODUTOS.map(p=>{
      const r1=c1[p.codigo_sap],r2=c2[p.codigo_sap];
      let badge='<span class="badge badge-neutral">aguardando</span>';
      if(r1&&r2){contados++;if(r1.quantidade===r2.quantidade){ok++;badge='<span class="badge badge-ok">OK</span>'}else{div++;badge='<span class="badge badge-danger">divergente</span>'}}
      else if(r1){badge='<span class="badge badge-warn">aguard. 2ª</span>'}
      else if(r2){badge='<span class="badge badge-warn">aguard. 1ª</span>'}
      return `<div class="product-row" style="display:flex;align-items:center;gap:10px">
        <div style="flex:1;min-width:0">
          <div style="font-family:var(--mono);font-size:11px;color:var(--text)">${p.codigo_sap}</div>
          <div style="font-size:10px;color:var(--text3);white-space:nowrap;overflow:hidden;text-overflow:ellipsis">${p.descricao}</div>
        </div>
        <div style="text-align:right;font-family:var(--mono);font-size:11px">
          <div style="color:var(--text2)">1ª: ${r1?r1.quantidade:'—'}</div>
          <div style="color:var(--text2)">2ª: ${r2?r2.quantidade:'—'}</div>
        </div>
        <div>${badge}</div>
      </div>`;
    }).join('');
    document.getElementById('res-total').textContent=total;
    document.getElementById('res-contados').textContent=contados;
    document.getElementById('res-ok').textContent=ok;
    document.getElementById('res-div').textContent=div;
    document.getElementById('sup-resumo-lista').innerHTML=rows;
  }catch(e){notify('Erro: '+e.message,'error')}
  loading(false);
}

async function renderDivergencias(){
  if(!state.supSessaoId){document.getElementById('sup-diverg-lista').innerHTML='<div class="empty"><div class="empty-icon">📊</div>Selecione uma sessão</div>';return}
  loading(true);
  try{
    const cSnap=await db.collection('contagens').where('sessao_id','==',state.supSessaoId).get();
    const c1={},c2={};
    cSnap.docs.forEach(d=>{const c=d.data();if(c.rodada===1)c1[c.codigo_sap]=c;else if(c.rodada===2)c2[c.codigo_sap]=c;});
    const divs=PRODUTOS.filter(p=>c1[p.codigo_sap]&&c2[p.codigo_sap]&&c1[p.codigo_sap].quantidade!==c2[p.codigo_sap].quantidade);
    const el=document.getElementById('sup-diverg-lista');
    if(!divs.length){el.innerHTML='<div class="empty"><div class="empty-icon">✅</div>Nenhuma divergência</div>';document.getElementById('btn-export').style.display='none';loading(false);return}
    el.innerHTML=divs.map(p=>{
      const r1=c1[p.codigo_sap],r2=c2[p.codigo_sap];
      const diff=r2.quantidade-r1.quantidade;
      return `<div class="card" style="border-left:3px solid var(--danger);padding:12px;margin-bottom:8px">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px">
          <div>
            <div style="font-family:var(--mono);font-size:12px;font-weight:600;color:var(--text)">${p.codigo_sap}</div>
            <div style="font-size:11px;color:var(--text3)">${p.descricao}</div>
          </div>
          <span class="badge badge-danger">Δ ${diff>0?'+':''}${diff} ${p.unidade}</span>
        </div>
        <div class="row2">
          <div style="text-align:center;background:var(--bg3);border-radius:8px;padding:8px">
            <div style="font-size:9px;color:var(--text3);font-family:var(--mono)">1ª CONTAGEM</div>
            <div style="font-size:18px;font-family:var(--mono);font-weight:600;color:var(--text2)">${r1.quantidade}</div>
            <div style="font-size:9px;color:var(--text3)">${r1.usuario_nome||''}</div>
          </div>
          <div style="text-align:center;background:var(--bg3);border-radius:8px;padding:8px">
            <div style="font-size:9px;color:var(--text3);font-family:var(--mono)">2ª CONTAGEM</div>
            <div style="font-size:18px;font-family:var(--mono);font-weight:600;color:var(--danger)">${r2.quantidade}</div>
            <div style="font-size:9px;color:var(--text3)">${r2.usuario_nome||''}</div>
          </div>
        </div>
      </div>`;
    }).join('');
    document.getElementById('btn-export').style.display='flex';
  }catch(e){notify('Erro: '+e.message,'error')}
  loading(false);
}

function abrirModalNovaSessao(){
  document.getElementById('modal-sessao-desc').value='';
  document.getElementById('modal-overlay').style.display='flex';
  setTimeout(()=>document.getElementById('modal-sessao-desc').focus(),200);
}
function fecharModal(){document.getElementById('modal-overlay').style.display='none'}

async function criarSessao(){
  const desc=document.getElementById('modal-sessao-desc').value.trim();
  if(!desc){notify('Informe uma descrição','error');return}
  loading(true);
  try{
    await db.collection('sessoes').add({
      descricao:desc,status:'aberta',rodada_atual:1,
      supervisor_id:state.user.id,supervisor_nome:state.user.nome,
      criado_em:firebase.firestore.FieldValue.serverTimestamp()
    });
    fecharModal();
    notify('Sessão criada!','success');
    await renderSessoes();
  }catch(e){notify('Erro: '+e.message,'error')}
  loading(false);
}

async function avancarRodada(id,rodadaAtual,status){
  const ra=parseInt(rodadaAtual);
  let newStatus,newRodada,msg;
  if(status==='aberta'){msg='Iniciar 1ª rodada de contagem?';newStatus='em_contagem';newRodada=1}
  else if(ra===1){msg='Avançar para 2ª contagem (cega)?';newStatus='em_contagem';newRodada=2}
  else{msg='Fechar sessão e gerar divergências?';newStatus='aguardando_revisao';newRodada=2}
  if(!confirm(msg))return;
  loading(true);
  try{
    await db.collection('sessoes').doc(id).update({status:newStatus,rodada_atual:newRodada});
    notify('Sessão atualizada!','success');
    state.supSessaoId=id;
    await renderSessoes();
  }catch(e){notify('Erro: '+e.message,'error')}
  loading(false);
}

async function exportarCSV(){
  if(!state.supSessaoId)return;
  const cSnap=await db.collection('contagens').where('sessao_id','==',state.supSessaoId).get();
  const c1={},c2={};
  cSnap.docs.forEach(d=>{const c=d.data();if(c.rodada===1)c1[c.codigo_sap]=c;else if(c.rodada===2)c2[c.codigo_sap]=c;});
  let csv='Codigo SAP;Descricao;Unidade;Localizacao;Qtd 1a;Qtd 2a;Diferenca;Status\n';
  PRODUTOS.forEach(p=>{
    const r1=c1[p.codigo_sap],r2=c2[p.codigo_sap];
    const q1=r1?r1.quantidade:'';const q2=r2?r2.quantidade:'';
    const diff=(r1&&r2)?r2.quantidade-r1.quantidade:'';
    const sit=r1&&r2?(r1.quantidade===r2.quantidade?'OK':'DIVERGENTE'):'INCOMPLETO';
    csv+=`${p.codigo_sap};${p.descricao};${p.unidade};${p.localizacao};${q1};${q2};${diff};${sit}\n`;
  });
  const blob=new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8;'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');a.href=url;a.download='inventario_'+new Date().toISOString().slice(0,10)+'.csv';a.click();URL.revokeObjectURL(url);
  notify('CSV exportado!','success');
}

// ═══════════════════ INIT ═══════════════════
(async function init(){
  const saved=sessionStorage.getItem('coletor_user');
  if(saved){
    try{
      state.user=JSON.parse(saved);
      if(state.user.perfil==='supervisor')await loadSupervisor();
      else await loadHome();
    }catch(e){}
  }
  document.getElementById('inp-senha').addEventListener('keydown',e=>{if(e.key==='Enter')doLogin()});
  document.getElementById('inp-login').addEventListener('keydown',e=>{if(e.key==='Enter')document.getElementById('inp-senha').focus()});
})();
</script>
